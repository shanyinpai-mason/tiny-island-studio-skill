    "personality": { "type": "string", "minLength": 1 },
    "visualBible": { "type": "string", "minLength": 1 },
    "turnaroundPrompt": { "type": "string", "minLength": 1 },
    "expressionPrompt": { "type": "string", "minLength": 1 },
    "posePrompt": { "type": "string", "minLength": 1 },
