{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "hook", "logline", "learningGoal", "emotionalGoal", "storyBeats"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "hook": { "type": "string", "minLength": 1 },
    "logline": { "type": "string", "minLength": 1 },
    "learningGoal": { "type": "string", "minLength": 1 },
    "emotionalGoal": { "type": "string", "minLength": 1 },
    "storyBeats": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 6,
      "maxItems": 8
    },
    "narrationMode": { "type": "string", "enum": ["spoken", "nonverbal"] },
    "narration": { "type": "string", "minLength": 1 },
    "audioActionScript": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "required": ["narrationMode"],
        "properties": { "narrationMode": { "const": "nonverbal" } }
      },
      "then": {
        "required": ["audioActionScript"],
        "not": { "required": ["narration"] }
      },
      "else": { "required": ["narration"] }
    }
  ]
}
