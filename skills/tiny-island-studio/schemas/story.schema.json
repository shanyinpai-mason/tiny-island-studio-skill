{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "hook", "logline", "learningGoal", "emotionalGoal", "storyBeats", "narration", "shots"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "hook": { "type": "string", "minLength": 1 },
    "logline": { "type": "string", "minLength": 1 },
    "learningGoal": { "type": "string", "minLength": 1 },
    "emotionalGoal": { "type": "string", "minLength": 1 },
    "storyBeats": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 6,
      "maxItems": 8
    },
    "narration": { "type": "string", "minLength": 1 },
    "shots": {
      "type": "array",
      "minItems": 8,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["no", "duration", "description", "sound"],
        "oneOf": [
          { "required": ["jimengPrompt"], "not": { "required": ["seedancePrompt"] } },
          { "required": ["seedancePrompt"], "not": { "required": ["jimengPrompt"] } }
        ],
        "properties": {
          "no": { "type": "integer", "minimum": 1 },
          "duration": { "type": "integer", "minimum": 2, "maximum": 15 },
          "description": { "type": "string", "minLength": 1 },
          "jimengPrompt": { "type": "string", "minLength": 1 },
          "seedancePrompt": { "type": "string", "minLength": 1 },
          "sound": { "type": "string" }
        }
      }
    }
  }
}
